# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (docker-compose default)
DATABASE_URL=postgresql://hkd:hkd@localhost:5432/hkd_pos?schema=public

# Redis (cache + BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace-with-32-char-random-hex
JWT_REFRESH_SECRET=replace-with-different-32-char-random-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OTP gateway (eSMS / Stringee). One must be configured for prod.
SMS_PROVIDER=esms
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=HKDPOS

# E-invoice provider — supported: vnpt | misa | viettel | easyinvoice | mock
EINVOICE_PROVIDER=mock
EINVOICE_BASE_URL=
EINVOICE_USERNAME=
EINVOICE_PASSWORD=
EINVOICE_TAX_CODE=
# Path to PFX/P12 signing cert (issued by tax authority CA: VNPT-CA, FPT-CA, etc.)
EINVOICE_CERT_PATH=
EINVOICE_CERT_PASSWORD=

# GDT (Tổng cục Thuế) eTax Mobile bridge
GDT_BASE_URL=https://etaxmobile.gdt.gov.vn
GDT_CLIENT_ID=
GDT_CLIENT_SECRET=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Mobile ───────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SENTRY_DSN=
