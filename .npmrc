# React Native's bundler (Metro) and many native-module postinstall scripts
# expect a flat node_modules layout. `hoist-pattern` instructs pnpm to put
# these specific subtrees at the top level while keeping the rest strict.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=expo*
public-hoist-pattern[]=*expo-*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@babel/core
public-hoist-pattern[]=@babel/preset-*
public-hoist-pattern[]=@babel/plugin-*
public-hoist-pattern[]=babel-preset-expo
public-hoist-pattern[]=metro*
public-hoist-pattern[]=@react-navigation/*
auto-install-peers=true
strict-peer-dependencies=false
