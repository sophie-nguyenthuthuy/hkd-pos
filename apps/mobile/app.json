{
  "expo": {
    "name": "HKD POS",
    "slug": "hkd-pos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hkdpos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.hkdpos.app"
    },
    "android": {
      "package": "vn.hkdpos.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "plugins": ["expo-secure-store", "expo-localization"],
    "extra": {
      "apiUrl": "$EXPO_PUBLIC_API_URL",
      "sentryDsn": "$EXPO_PUBLIC_SENTRY_DSN"
    }
  }
}
