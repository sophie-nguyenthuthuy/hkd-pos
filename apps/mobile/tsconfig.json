{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "noEmit": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["jest", "react-native"]
  },
  "include": ["src/**/*", "App.tsx", "index.ts"],
  "exclude": ["node_modules", ".expo", "dist"]
}
